# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Gemini API key. Enables the cloud read of the banknote serial number and
# denomination (NETRA tries Gemini first, then falls back to offline EasyOCR).
# Leave blank to run fully offline — the genuine/counterfeit verdict never
# depends on it. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional NETRA tuning -------------------------------------------------
# NETRA_GEMINI_MODEL=gemini-2.5-flash   # cheapest tier that reads the serial
# NETRA_GEMINI_TIMEOUT=12               # seconds before falling back to local
# NETRA_DISABLE_CLOUD=1                 # force fully-offline operation
# NETRA_ENABLE_OCR=0                    # disable EasyOCR (faster, no serials)
# NETRA_DISABLE_CLIP=1                  # disable the is-it-a-banknote model
